NODE_ENV=production
PORT=3001
LOG_LEVEL=info
LOG_PRETTY=false

DATABASE_URL=<from erp-pg-app secret, db=erp-hr>
REDIS_URL=<redis://:<redis-password>@redis-master.erp-data.svc.cluster.local:6379/0>
HR_REDIS_URL=<redis://:<redis-password>@redis-master.erp-data.svc.cluster.local:6379/0>

INTERNAL_SERVICE_SECRET=<from secret>
SERVICE_JWT_AUDIENCE=trusoft-erp-internal
SERVICE_JWT_ISSUER=trusoft-erp
SERVICE_JWT_SELF_ISSUER=erp-hr-backend
SERVICE_JWT_ACCEPT_HS256=true
SERVICE_JWT_SECRET=<from secret>
SERVICE_JWT_PUBLIC_KEYS_JSON={}

HR_C4_ENCRYPTION_KEY=<32-byte base64 secret>
HR_C4_BLIND_INDEX_KEY=<32-byte base64 secret>

ATTENDANCE_LISTENER_ENABLED=false
ATTENDANCE_BOOTSTRAP_ENABLED=false
DAM_SERVICE_URL=http://erp-dam-backend.erp-svc.svc.cluster.local:3000
HR_SERVICE_URL=http://erp-hr-backend.erp-svc.svc.cluster.local:3000
