// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== EXISTING ENUMS ====================
enum StatusAttandance {
  PRESENT
  ABSENT
  LATE
}

enum LeaveStatus {
  PENDING
  REJECTED
  APPROVED
}

enum ReviewStatus {
  IN_PROGRESS
  FINALIZED
  DRAFT
}

enum RequisitionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  POSTED
  CLOSED
}

enum CourseMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum CourseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
  REJECTED
}

enum ReminderType {
  PENDING_REVIEW
  LATE_SUBMISSION
  FEEDBACK_REQUEST
}

enum ReviewType {
  SELF
  MANAGER
  PEER
  HR
}

enum CalibrationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ==================== NEW PAYROLL ENUMS ====================
enum PayrollRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
}

enum PayslipStatus {
  DRAFT
  FINALIZED
  DISTRIBUTED
}

enum PayElementType {
  EARNING
  DEDUCTION
}

enum PayFrequency {
  WEEKLY
  BI_WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

// ==================== EXISTING MODELS ====================
model Log {
  id          Int       @id @default(autoincrement())
  employee    Employee? @relation(fields: [employeeId], references: [id])
  employeeId  Int?
  type        String
  action_type String
  module      String
  ip          String
  os          String
  result      String
  action_by   Employee? @relation("ActionBy", fields: [actionById], references: [id])
  actionById  Int?
  notes       String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  attandaceId Int?
  attandance  Attendance? @relation("AttandanceMark", fields: [attandaceId], references: [id])

  // New payroll relations
  payrollRun   PayrollRun?     @relation(fields: [payrollRunId], references: [id])
  payrollRunId Int?
  payslip      PayrollPayslip? @relation(fields: [payslipId], references: [id])
  payslipId    Int?
}

model Employee {
  id         Int      @id @default(autoincrement())
  first_name String?
  last_name  String?
  gender     String?
  job_title  String
  hire_date  DateTime
  status     String
  userId     Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Existing relations
  attendance            Attendance[]
  leaves                Leave[]
  reviewsGiven          PerformanceReview[]   @relation("Reviewer")
  reviewsReceived       PerformanceReview[]   @relation("EmployeeReviews")
  feedbackGiven         ReviewFeedback[]      @relation("FeedbackByEmployee")
  Position              Position?             @relation(fields: [positionId], references: [id])
  positionId            Int?
  requisitionsRequested JobRequisition[]      @relation("RequestedBy")
  requisitionsApproved  JobRequisition[]      @relation("ApprovedBy")
  approvals             RequisitionApproval[]
  JobRequisition        JobRequisition[]
  TrainingCourse        TrainingCourse[]
  TrainingEnrollment    TrainingEnrollment[]
  positionCreatedBy     Position[]            @relation("CreatedBy")
  actionBy              Log[]                 @relation("ActionBy")
  logs                  Log[]
  goalCreatedBy         Goal[]                @relation("GoalCreatedBy")
  approvedBy            Goal[]                @relation("GoalApprover")
  goalProgress          GoalProgress[]        @relation("Goal progress")
  feedBackBy            ReviewFeedback[]      @relation("FeedbackBy")
  ReviewReminder        ReviewReminder[]
  calibratedBy          RatingAdjustment[]    @relation("CalibratedBy")

  // New payroll relations
  payrollPayslips    PayrollPayslip[]
  employmentTerms    EmploymentTerms[]
  payrollAssignments PayrollAssignment[]
  bankDetails        BankDetail[]
  PayrollAuditLog    PayrollAuditLog[]
}

// 🕒 Attendance model
model Attendance {
  id          Int              @id @default(autoincrement())
  employeeId  Int
  date        DateTime         @default(now())
  check_in    DateTime?
  check_out   DateTime?
  total_hours Float? // computed at checkout time
  status      StatusAttandance @default(ABSENT)
  remarks     String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  logs     Log[]    @relation("AttandanceMark")
}

// 🏖️ Leave model
model Leave {
  id          Int         @id @default(autoincrement())
  employeeId  Int
  type        String // e.g. Sick, Casual, Vacation
  start_date  DateTime
  end_date    DateTime
  total_days  Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  approved_by Int? // admin/manager userId if applicable
  approved_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model PerformanceReview {
  id             Int          @id @default(autoincrement())
  employeeId     Int?
  reviewerId     Int?
  cycleId        Int? // ✅ NEW
  period_start   DateTime?
  period_end     DateTime?
  overall_rating Float?
  comments       String?
  submittedAt    DateTime?
  status         ReviewStatus @default(IN_PROGRESS)
  type           ReviewType   @default(SELF)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  // ✅ Relations
  employee  Employee?         @relation("EmployeeReviews", fields: [employeeId], references: [id])
  reviewer  Employee?         @relation("Reviewer", fields: [reviewerId], references: [id])
  feedbacks ReviewFeedback[]
  cycle     PerformanceCycle? @relation(fields: [cycleId], references: [id])

  reminders            ReviewReminder[] // link to reminder model
  CalibrationSession   CalibrationSession? @relation("Calibration Perdformance Reviews", fields: [calibrationSessionId], references: [id])
  calibrationSessionId Int?
  RatingAdjustment     RatingAdjustment[]  @relation("Rating Performance Review")
}

model ReviewFeedback {
  id           Int      @id @default(autoincrement())
  reviewId     Int
  reviewerId   Int // by employee
  feedbackById Int?
  feedback     String
  rating       Float?
  created_at   DateTime @default(now())

  // ✅ Relations
  review     PerformanceReview @relation(fields: [reviewId], references: [id])
  reviewer   Employee          @relation("FeedbackByEmployee", fields: [reviewerId], references: [id])
  feedbackBy Employee?         @relation("FeedbackBy", fields: [feedbackById], references: [id])
}

model Position {
  id             Int              @id @default(autoincrement())
  title          String
  description    String?
  createdById    Int?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  employees      Employee[] // One position can have multiple employees
  JobRequisition JobRequisition[]
  createdBy      Employee?        @relation("CreatedBy", fields: [createdById], references: [id])
}

model JobRequisition {
  id            Int               @id @default(autoincrement())
  title         String
  description   String?
  departmentId  Int?
  positionId    Int?
  requestedById Int
  approvedById  Int?
  employeeId    Int? // Optional link to an employee (e.g., replacement for existing staff)
  openings      Int               @default(1)
  status        RequisitionStatus @default(DRAFT)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // ✅ Relations
  // department  Department?           @relation(fields: [departmentId], references: [id])
  position    Position?             @relation(fields: [positionId], references: [id])
  requestedBy Employee              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy  Employee?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvals   RequisitionApproval[]
  postings    JobPosting[]
  employee    Employee?             @relation(fields: [employeeId], references: [id])
}

model RequisitionApproval {
  id            Int       @id @default(autoincrement())
  requisitionId Int
  approverId    Int
  status        String    @default("PENDING")
  comments      String?
  decidedAt     DateTime?

  // Relations
  requisition JobRequisition @relation(fields: [requisitionId], references: [id])
  approver    Employee       @relation(fields: [approverId], references: [id])
}

model JobPosting {
  id            Int      @id @default(autoincrement())
  requisitionId Int
  externalUrl   String?
  isActive      Boolean  @default(true)
  postedAt      DateTime @default(now())

  // Relations
  requisition JobRequisition @relation(fields: [requisitionId], references: [id])
}

model TrainingCategory {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  courses     TrainingCourse[]
}

model TrainingCourse {
  id            Int          @id @default(autoincrement())
  title         String
  description   String?
  categoryId    Int
  instructorId  Int?
  durationHours Int?
  location      String?
  mode          CourseMode   @default(ONLINE)
  startDate     DateTime?
  endDate       DateTime?
  status        CourseStatus @default(DRAFT)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  category    TrainingCategory     @relation(fields: [categoryId], references: [id])
  instructor  Employee?            @relation(fields: [instructorId], references: [id])
  enrollments TrainingEnrollment[]
}

model TrainingEnrollment {
  id             Int              @id @default(autoincrement())
  courseId       Int
  employeeId     Int
  enrollmentDate DateTime         @default(now())
  progress       Float            @default(0)
  status         EnrollmentStatus @default(ENROLLED)
  completionDate DateTime?

  course   TrainingCourse @relation(fields: [courseId], references: [id])
  employee Employee       @relation(fields: [employeeId], references: [id])
}

model PerformanceCycle {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  start_date  DateTime
  end_date    DateTime
  status      CycleStatus @default(DRAFT)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  template           PerformanceTemplate? @relation(fields: [templateId], references: [id])
  templateId         Int?
  reviews            PerformanceReview[]
  CalibrationSession CalibrationSession[] @relation("Calibration Performance Cyclce")
}

model PerformanceTemplate {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  criteria       Json? // e.g. ["Teamwork", "Communication", "Problem Solving"]
  overall_rating Float?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  cycles PerformanceCycle[]
}

model Goal {
  id            Int        @id @default(autoincrement())
  employeeId    Int?
  title         String
  description   String?
  category      String? // e.g. "Personal", "Team", "Company"
  start_date    DateTime
  end_date      DateTime
  target_value  Float?
  current_value Float?     @default(0)
  progress      Float?     @default(0)
  status        GoalStatus @default(PENDING)
  approvedById  Int?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  // Relations
  employee        Employee?       @relation("GoalCreatedBy", fields: [employeeId], references: [id])
  approvedBy      Employee?       @relation("GoalApprover", fields: [approvedById], references: [id])
  progressUpdates GoalProgress[]
  parentGoal      GoalAlignment[] @relation("GoalAlignmentsParent")
  alignedGoal     GoalAlignment[] @relation("GoalAlignmentsChild")
  goal            GoalAlignment[]
}

model GoalProgress {
  id          Int      @id @default(autoincrement())
  goalId      Int?
  update_date DateTime @default(now())
  comment     String?
  progress    Float
  created_by  Int

  // Relations
  goal      Goal?     @relation(fields: [goalId], references: [id])
  createdBy Employee? @relation("Goal progress", fields: [created_by], references: [id])
}

model GoalAlignment {
  id            Int  @id @default(autoincrement())
  parentGoalId  Int?
  alignedGoalId Int?

  // Relations
  parentGoal  Goal? @relation("GoalAlignmentsParent", fields: [parentGoalId], references: [id])
  alignedGoal Goal? @relation("GoalAlignmentsChild", fields: [alignedGoalId], references: [id])
  Goal        Goal? @relation(fields: [goalId], references: [id])
  goalId      Int?
}

model ReviewReminder {
  id       Int          @id @default(autoincrement())
  reviewId Int
  sentToId Int
  sentAt   DateTime     @default(now())
  type     ReminderType @default(PENDING_REVIEW)

  review PerformanceReview @relation(fields: [reviewId], references: [id])
  sentTo Employee          @relation(fields: [sentToId], references: [id])
}

model CalibrationSession {
  id           Int               @id @default(autoincrement())
  name         String
  cycleId      Int?
  started_at   DateTime?         @default(now())
  completed_at DateTime?
  status       CalibrationStatus @default(PENDING)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  // Relations
  performance_reviews PerformanceReview[] @relation("Calibration Perdformance Reviews")
  ratingAdjustments   RatingAdjustment[]  @relation("CalibrationSessions")
  cycle               PerformanceCycle?   @relation("Calibration Performance Cyclce", fields: [cycleId], references: [id])
}

model RatingAdjustment {
  id                        Int      @id @default(autoincrement())
  reviewId                  Int?
  calibrationSessionId      Int?
  old_rating                Float
  new_rating                Float
  justification             String?
  calibrated_by_employee_id Int?
  created_at                DateTime @default(now())

  // Relations
  calibrationSession CalibrationSession? @relation("CalibrationSessions", fields: [calibrationSessionId], references: [id])
  performance_review PerformanceReview?  @relation("Rating Performance Review", fields: [reviewId], references: [id])
  calibratedBy       Employee?           @relation("CalibratedBy", fields: [calibrated_by_employee_id], references: [id])
}

// ==================== NEW PAYROLL MODELS ====================

// Core Payroll Entities
model PayrollRun {
  id              Int              @id @default(autoincrement())
  periodStart     DateTime
  periodEnd       DateTime
  countryCode     String           @db.Char(2)
  currencyCode    String           @db.Char(3)
  status          PayrollRunStatus @default(PENDING)
  totalGross      Float?           @default(0)
  totalDeductions Float?           @default(0)
  totalNet        Float?           @default(0)
  employeeCount   Int?             @default(0)
  processedAt     DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  // Relations
  payslips        PayrollPayslip[]
  logs            Log[]
  PayrollAuditLog PayrollAuditLog[]

  @@unique([periodStart, periodEnd])
  @@map("payroll_runs")
}

model PayrollPayslip {
  id              Int           @id @default(autoincrement())
  payrollRunId    Int
  employeeId      Int
  grossAmount     Float
  totalDeductions Float
  netAmount       Float
  distributedAt   DateTime?
  status          PayslipStatus @default(DRAFT)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  // Relations
  payrollRun      PayrollRun         @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee        Employee           @relation(fields: [employeeId], references: [id])
  earnings        PayrollEarning[]
  deductions      PayrollDeduction[]
  logs            Log[]
  PayrollAuditLog PayrollAuditLog[]

  @@unique([payrollRunId, employeeId])
  @@map("payroll_payslips")
}

model PayrollEarning {
  id            Int      @id @default(autoincrement())
  payslipId     Int
  earningTypeId Int
  amount        Float
  description   String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  payslip     PayrollPayslip     @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  earningType PayrollEarningType @relation(fields: [earningTypeId], references: [id])

  @@map("payroll_earnings")
}

model PayrollDeduction {
  id              Int      @id @default(autoincrement())
  payslipId       Int
  deductionTypeId Int
  amount          Float
  description     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  payslip       PayrollPayslip       @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  deductionType PayrollDeductionType @relation(fields: [deductionTypeId], references: [id])

  @@map("payroll_deductions")
}

// Configuration Tables
model PayrollEarningType {
  id          Int            @id @default(autoincrement())
  code        String         @unique
  name        String
  description String?
  type        PayElementType @default(EARNING)
  isTaxable   Boolean        @default(true)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  // Relations
  earnings    PayrollEarning[]
  assignments PayrollAssignment[]

  @@map("payroll_earning_types")
}

model PayrollDeductionType {
  id          Int            @id @default(autoincrement())
  code        String         @unique
  name        String
  description String?
  type        PayElementType @default(DEDUCTION)
  rate        Float? // Percentage rate for calculations
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  // Relations
  deductions  PayrollDeduction[]
  assignments PayrollAssignment[]

  @@map("payroll_deduction_types")
}

// Employee Payroll Data
model EmploymentTerms {
  id            Int          @id @default(autoincrement())
  employeeId    Int
  baseSalary    Float
  currency      String       @default("USD")
  payFrequency  PayFrequency
  effectiveFrom DateTime
  effectiveTo   DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employment_terms")
}

model PayrollAssignment {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  earningTypeId   Int?
  deductionTypeId Int?
  amount          Float?
  rate            Float?
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isActive        Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  // Relations
  employee      Employee              @relation(fields: [employeeId], references: [id])
  earningType   PayrollEarningType?   @relation(fields: [earningTypeId], references: [id])
  deductionType PayrollDeductionType? @relation(fields: [deductionTypeId], references: [id])

  @@map("payroll_assignments")
}

model BankDetail {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  bankName      String
  accountNumber String
  routingNumber String?
  accountType   String   @default("CHECKING")
  isPrimary     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, accountNumber])
  @@map("bank_details")
}

// Tax Configuration (Simplified)
model TaxRate {
  id            Int       @id @default(autoincrement())
  countryCode   String    @db.Char(2)
  bracketMin    Float
  bracketMax    Float?
  rate          Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("tax_rates")
}

// Audit Log for Payroll
model PayrollAuditLog {
  id           Int      @id @default(autoincrement())
  action       String
  details      String?
  payrollRunId Int?
  payslipId    Int?
  employeeId   Int?
  oldValues    Json?
  newValues    Json?
  created_at   DateTime @default(now())

  // Relations
  payrollRun PayrollRun?     @relation(fields: [payrollRunId], references: [id])
  payslip    PayrollPayslip? @relation(fields: [payslipId], references: [id])
  employee   Employee?       @relation(fields: [employeeId], references: [id])

  @@map("payroll_audit_logs")
}
