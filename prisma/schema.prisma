model ReimbursementClaim {
  id             Int                 @id @default(autoincrement())
  employeeId     Int
  title          String
  amount         Float
  currency       String              @default("USD")
  category       String?
  receiptMediaId Int?
  status         ReimbursementStatus @default(DRAFT)
  submittedAt    DateTime?
  approvedById   Int?
  approvedAt     DateTime?
  paidAt         DateTime?
  notes          String?
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt

  employee   Employee  @relation("ReimbursementEmployee", fields: [employeeId], references: [id])
  approvedBy Employee? @relation("ReimbursementApprover", fields: [approvedById], references: [id])

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
  @@map("reimbursement_claims")
}

// HR-BENEFITS-04 — a benefit plan a tenant offers (health / retirement /
// allowance / other). Money fields are carried as INTEGER MINOR UNITS (cents)
// per src/lib/money.js — the API boundary converts to/from major units. Plans
// are tenant-scoped (RBAC Company.uuid, verified service-JWT claim; fail-closed).
model BenefitPlan {
  id                        Int         @id @default(autoincrement())
  tenantId                  String?     @db.Uuid
  name                      String
  type                      BenefitType
  description               String?
  // Stored in integer minor units (cents) — see src/lib/money.js.
  employerContributionMinor Int?
  employeeContributionMinor Int?
  active                    Boolean     @default(true)
  created_at                DateTime    @default(now())
  updated_at                DateTime    @updatedAt

  enrollments EmployeeBenefit[]

  @@index([tenantId])
  @@map("benefit_plans")
}

// HR-BENEFITS-04 — enrollment join between an Employee and a BenefitPlan.
// electedAmount (employee-chosen contribution/allowance) is integer minor units.
model EmployeeBenefit {
  id                 Int                   @id @default(autoincrement())
  tenantId           String?               @db.Uuid
  employeeId         Int
  benefitPlanId      Int
  enrolledAt         DateTime              @default(now())
  status             EmployeeBenefitStatus @default(ACTIVE)
  electedAmountMinor Int?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt

  employee    Employee    @relation("EmployeeBenefits", fields: [employeeId], references: [id])
  benefitPlan BenefitPlan @relation(fields: [benefitPlanId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([benefitPlanId])
  @@map("employee_benefits")
}

// ==================== OUTBOX (A.4 · ARCH-01 §7–§8) ====================
//
// Transactional outbox for HR fabric events. A domain event (today
// `hr.employee.lifecycle.v1`) is written into this table INSIDE the same
// transaction as the source aggregate (Employee create/update/terminate), so
// the event and the business write commit or roll back together — no lost or
// phantom events. A separate claim/lease dispatcher (src/jobs/outbox.dispatcher
// .js) drains unpublished rows and XADDs the persisted EventEnvelope to a Redis
// stream. Mirrors erp-communication-backend's CommunicationOutbox shape.
//
// payload is the full @trusoft/contracts EventEnvelope (validate-before-write),
// whose `.payload` is the HrEmployeeLifecycleV1 ids-only payload.
model OutboxEvent {
  id            String    @id @default(uuid())
  tenantId      String    @db.Uuid
  eventName     String // e.g. 'hr.employee.lifecycle.v1'
  aggregateType String // 'Employee'
  aggregateId   String // stringified source row id
  payload       Json // a conformant EventEnvelope
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?
  attempts      Int       @default(0)
  lastError     String?

  // Lease-based claim so multiple dispatcher replicas coordinate without an
  // external lock service. A row is claimable when publishedAt IS NULL AND
  // (claimedAt IS NULL OR claimExpiresAt < NOW()). claimedBy is a bounded,
  // PII-free worker id.
  claimedAt      DateTime?
  claimedBy      String?
  claimExpiresAt DateTime?

  @@index([tenantId, publishedAt])
  @@index([publishedAt, createdAt])
  // Dispatcher candidate scan (free or expired claim).
  @@index([publishedAt, claimExpiresAt, createdAt])
  @@map("outbox_events")
}

