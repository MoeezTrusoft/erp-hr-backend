model BankDetail {
  id                Int      @id @default(autoincrement())
  tenantId          String?  @db.Uuid // HR-04 / T-P2.2 + REQ-007 — RBAC Company.uuid (verified service-JWT claim; was Int companyId)
  employeeId        Int
  bankName          String
  // HR-01 / T-P4.2 — C4 bank account encrypted at rest (AES-256-GCM envelope).
  // GCM uses a random IV so ciphertext differs per write, which would break the
  // old @@unique([employeeId, accountNumber]) and any lookup-by-account. The
  // accountNumberBidx column below holds a deterministic HMAC (blind index) of
  // the plaintext; uniqueness and equality lookups move to it (see the prisma
  // C4 extension). The encrypted value still lives in accountNumber.
  accountNumber     String
  accountNumberBidx String? // HR-01 / T-P4.2 — deterministic HMAC of the plaintext account for unique + lookup
  routingNumber     String? // HR-01 / T-P4.2 — C4 routing number encrypted at rest
  accountType       String   @default("CHECKING")
  // Consolidated-profile fields (additive nullable).
  accountTitle       String? // A/C Title — name the account is held under
  iban               String? // C4-encrypted at rest (C4_FIELDS.bankDetail.iban); embeds the account number
  branch             String? // bank branch name / code
  disbursementMethod String? // how net pay is disbursed: Bank Transfer | Cheque | Cash
  isPrimary         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])

  // HR-01 / T-P4.2 — uniqueness moved off the (now-encrypted) accountNumber to
  // its blind index so a duplicate account is still rejected.
  @@unique([employeeId, accountNumberBidx])
  @@index([tenantId])
  @@map("bank_details")
}

