// ==================== PAYROLL MODELS ====================

model PayrollRun {
  id               Int              @id @default(autoincrement())
  tenantId         String?          @db.Uuid // HR-04 / T-P2.2 + REQ-007 — RBAC Company.uuid (verified service-JWT claim; was Int companyId)
  periodStart      DateTime
  periodEnd        DateTime
  countryCode      String           @db.Char(2)
  currencyCode     String           @db.Char(3)
  status           PayrollRunStatus @default(PENDING)
  totalGross       Float?           @default(0)
  totalDeductions  Float?           @default(0)
  totalNet         Float?           @default(0)
  employeeCount    Int?             @default(0)
  processedAt      DateTime?
  // HR-02 / T-P4.1 — separation of duties + reproducibility.
  // processedBy : employee id that ran processing (the processor).
  // approvedBy  : employee id that approved the run; MUST differ from
  //               processedBy (no self-approval). FINALIZE requires this set.
  // approvedAt  : when approval was recorded.
  // ruleVersion / ratesEffectiveAt : the versioned tax/rule snapshot the run
  //               was computed against, so the run is reproducible against the
  //               rates that were in effect (not whatever the table holds now).
  processedBy      Int?
  approvedBy       Int?
  approvedAt       DateTime?
  ruleVersion      String?
  ratesEffectiveAt DateTime?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  // Relations
  payslips        PayrollPayslip[]
  logs            Log[]
  PayrollAuditLog PayrollAuditLog[]

  // REQ-006 follow-up / REQ-007 — period uniqueness is tenant-scoped: a period
  // is unique WITHIN a tenant, so two DIFFERENT tenants may each own the same
  // (periodStart, periodEnd). The app-level overlap guard in createPayrollRun is
  // already tenant-scoped (withTenant), so this aligns the DB constraint with it.
  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId])
  @@map("payroll_runs")
}

model PayrollPayslip {
  id              Int           @id @default(autoincrement())
  tenantId        String?       @db.Uuid // HR-04 / T-P2.2 + REQ-007 — RBAC Company.uuid (verified service-JWT claim; was Int companyId)
  payrollRunId    Int
  employeeId      Int
  grossAmount     Float
  totalDeductions Float
  netAmount       Float
  // HR-02 / T-P4.1 — the rule/rate version this payslip was computed against,
  // copied from its run so a single payslip is independently reproducible.
  ruleVersion     String?
  distributedAt   DateTime?
  status          PayslipStatus @default(DRAFT)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  // Relations
  payrollRun      PayrollRun         @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee        Employee           @relation(fields: [employeeId], references: [id])
  earnings        PayrollEarning[]
  deductions      PayrollDeduction[]
  logs            Log[]
  PayrollAuditLog PayrollAuditLog[]

  @@unique([payrollRunId, employeeId])
  @@index([tenantId])
  @@map("payroll_payslips")
}

