  completedAt DateTime?
  created_at  DateTime      @default(now())

  plan DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
  @@map("development_plan_items")
