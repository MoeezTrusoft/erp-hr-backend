model EmploymentTerms {
  id              Int          @id @default(autoincrement())
  tenantId        String?      @db.Uuid // HR-04 / T-P2.2 + REQ-007 — RBAC Company.uuid (verified service-JWT claim; was Int companyId)
  employeeId      Int
  // HR-01 / T-P4.2 — C4 salary/comp encrypted at rest (was Float). Stored as a
  // self-describing AES-256-GCM envelope string; the prisma C4 extension
  // decrypts to a Number on read so callers (payroll/analytics) are unchanged.
  baseSalary      String
  currency        String       @default("USD")
  payFrequency    PayFrequency
  bonusTarget     String? // HR-01 / T-P4.2 — C4 bonus encrypted at rest (was Float?)
  // Equity component (RSUs/options/grant value) — free-form, C4-encrypted at rest
  // (C4_FIELDS.employmentTerms.equity). Additive nullable. Job & Comp tab.
  equity          String?
  equalityDetails String?
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@map("employment_terms")
}

