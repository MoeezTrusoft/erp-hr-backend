// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================
enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveAccrualPeriod {
  NONE
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum StatusAttendance {
  PRESENT
  ABSENT
  LATE
}

enum LeaveStatus {
  PENDING
  REJECTED
  APPROVED
}

enum ReviewStatus {
  IN_PROGRESS
  FINALIZED
  DRAFT
}

enum RequisitionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  POSTED
  CLOSED
}

enum CourseMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum CourseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
  REJECTED
}

enum ReminderType {
  PENDING_REVIEW
  LATE_SUBMISSION
  FEEDBACK_REQUEST
}

enum ReviewType {
  SELF
  MANAGER
  PEER
  HR
}

enum CalibrationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PayrollRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  APPROVED // HR-02 / T-P4.1 — human-approved (distinct approver) and ready to FINALIZE
  FINALIZED // HR-02 / T-P4.1 — finalized after approval; payslips locked for distribution
  CANCELLED
  FAILED
}

enum PayslipStatus {
  DRAFT
  FINALIZED
  DISTRIBUTED
}

enum PayElementType {
  EARNING
  DEDUCTION
}

enum PayFrequency {
  WEEKLY
  BI_WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum TimeEntryType {
  CLOCK_IN
  CLOCK_OUT
  BREAK_START
  BREAK_END
  MANUAL_ENTRY
}

enum WorkType {
  REGULAR
  OVERTIME
  HOLIDAY
  VACATION
  SICK
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

// ==================== MODELS ====================

model DashboardLayout {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  dashboardType String   @default("workforce")
  layout        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@unique([dashboardType])
  @@index([tenantId])
}

model Employee {
  id                   Int       @id @default(autoincrement())
  tenant_id            String?   @db.Uuid // REQ-007 — RBAC Company.uuid (was Int companyId)
  first_name           String?
  middle_name          String?
  last_name            String?
  preferred_name       String?
  nationality_id_type  String?
  employee_code        String?   @db.VarChar(50)
  date_of_birth        DateTime?
  joining_date         DateTime?
  probation_end_date   DateTime?
  employee_type        String? // contract permenant etc..
  work_mode            String? // Remote | Onsite | Hybrid
  remarks              String?
  marital_status       String?
  nationality          String?
  nationality_id_no    String?
  nationality_id       Int?
  current_address      String?
  permenant_address    String?
  city                 String?
  state                String?
  province             String?
  country              String?
  postal_code          String?
  personal_contact     String?
  email                String?
  work_email           String?
  work_phone           String?
  employement_status   String? // Active/ Inactive
  photo_url            String?
  cover_photo_url      String?
  cover_photo_media_id Int?
  updatedById          Int?
  createdById          Int?
  additional_fields    Json?
  gender               String?
  job_title            String?
  hire_date            DateTime?
  status               String?
  userId               Int?
  employee_media_id    Int?
  employee_name        String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  // NEW FIELDS
  // Pakistan National Tax Number. Additive nullable; C4-encrypted at rest via the
  // prisma C4 extension (C4_FIELDS.employee.ntn) — plaintext string in memory.
  ntn            String?
  businessUnitId Int? // Business Unit / Platform
  gradeLevelId   Int? // Employee Grade
  managerId      Int? // Direct Supervisor (Manager)
  reportToId     Int? // Functional Reporting (if different from manager)
  fte            Float? // Full-Time Equivalent (0.0–1.0)
  tenureMonths   String? // Tenure in months (system-calculated)

  // Existing relations
  emergencyContact      EmergencyContacts[]   @relation("RelationWithEmployee")
  attendance            Attendance[]
  leaves                Leave[]
  reviewsGiven          PerformanceReview[]   @relation("Reviewer")
  reviewsReceived       PerformanceReview[]   @relation("EmployeeReviews")
  feedbackGiven         ReviewFeedback[]      @relation("FeedbackByEmployee")
  Position              Position?             @relation(fields: [positionId], references: [id])
  positionId            Int?
  requisitionsRequested JobRequisition[]      @relation("RequestedBy")
  requisitionsApproved  JobRequisition[]      @relation("ApprovedBy")
  approvals             RequisitionApproval[]
  JobRequisition        JobRequisition[]
  TrainingCourse        TrainingCourse[]
  TrainingEnrollment    TrainingEnrollment[]
  // positionCreatedBy     Position[]            @relation("CreatedBy")
  actionBy              Log[]                 @relation("ActionBy")
  logs                  Log[]
  goalCreatedBy         Goal[]                @relation("GoalCreatedBy")
  approvedBy            Goal[]                @relation("GoalApprover")
  goalProgress          GoalProgress[]        @relation("GoalProgressCreatedBy")
  feedBackBy            ReviewFeedback[]      @relation("FeedbackBy")
  ReviewReminder        ReviewReminder[]
  calibratedBy          RatingAdjustment[]    @relation("CalibratedBy")

  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  gradeLevel   GradeLevel?   @relation(fields: [gradeLevelId], references: [id])
  manager      Employee?     @relation("ManagerRelation", fields: [managerId], references: [id])
  reportTo     Employee?     @relation("ReportToRelation", fields: [reportToId], references: [id])
  teamMembers  Employee[]    @relation("ManagerRelation")
  reports      Employee[]    @relation("ReportToRelation")

  // Payroll relations
  payrollPayslips    PayrollPayslip[]
  employmentTerms    EmploymentTerms[]
  payrollAssignments PayrollAssignment[]
  bankDetails        BankDetail[]
  PayrollAuditLog    PayrollAuditLog[]
  TimeEntry          TimeEntry[]
  Timesheet          Timesheet[]
  TimeApproval       TimeApproval[]
  WorkSchedule       WorkSchedule[]

  // Leave Management relations
  leavePoliciesCreated     LeavePolicy[]             @relation("LeavePolicyCreatedBy")
  leavePoliciesUpdated     LeavePolicy[]             @relation("LeavePolicyUpdatedBy")
  leaveRequestsCreated     LeaveRequest[]            @relation("LeaveRequestCreatedBy")
  leaveRequestsUpdated     LeaveRequest[]            @relation("LeaveRequestUpdatedBy")
  approvalWorkflowsCreated ApprovalWorkflow[]        @relation("ApprovalWorkflowCreatedBy")
  approvalWorkflowsUpdated ApprovalWorkflow[]        @relation("ApprovalWorkflowUpdatedBy")
  holidayCalendarsCreated  HolidayCalendar[]         @relation("HolidayCalendarCreatedBy")
  holidayCalendarsUpdated  HolidayCalendar[]         @relation("HolidayCalendarUpdatedBy")
  holidaysCreated          Holiday[]                 @relation("HolidayCreatedBy")
  holidaysUpdated          Holiday[]                 @relation("HolidayUpdatedBy")
  leaveBalancesUpdated     LeaveBalance[]            @relation("LeaveBalanceUpdatedBy")
  leaveRequestApprovals    LeaveRequestApproval[]    @relation("LeaveRequestApprovalCreatedBy")
  employeeHolidayCalendars EmployeeHolidayCalendar[]

  // Direct relations for leave management
  leaveRequests         LeaveRequest[]
  leaveBalances         LeaveBalance[]
  approvedLeaveRequests LeaveRequestApproval[]
  region                Region?                @relation(fields: [regionId], references: [id])
  regionId              Int?
  regionsCreated        Region[]               @relation("RegionCreatedBy")
  regionsUpdated        Region[]               @relation("RegionUpdatedBy")
  employee_media        EmployeeMedia[]        @relation("employeeMedia")
  dashboardLayouts      DashboardLayout[]

  // Onboarding relations
  onboardingChecklists OnboardingChecklist[]
  onboardingDocuments  OnboardingDocument[]
  onboardingSurveys    OnboardingSurvey[]
  buddyAssignments     OnboardingBuddy[]     @relation("BuddyRelation")

  // Recruitment relations
  interviewPanels          InterviewInterviewer[]
  interviewScorecardsGiven InterviewScorecard[]   @relation("ScorecardReviewer")

  // Learning & Development relations
  certifications          Certification[]
  recognitions            Recognition[]
  facilitatedSessions     TrainingSession[]         @relation("SessionFacilitator")
  sessionAttendances      TrainingSessionAttendee[]
  learningPathEnrollments LearningPathEnrollment[]

  // Employee management relations
  skills                   EmployeeSkill[]
  lifecycleEvents          EmployeeLifecycleEvent[]
  offboardingChecklist     OffboardingChecklist?
  offboardingTasksAssigned OffboardingTask[]

  // Compliance, IDP, Reimbursement relations
  complianceItems        ComplianceItem[]
  developmentPlans       DevelopmentPlan[]
  reimbursementClaims    ReimbursementClaim[]  @relation("ReimbursementEmployee")
  reimbursementsApproved ReimbursementClaim[]  @relation("ReimbursementApprover")
  documentExpiryAlerts   DocumentExpiryAlert[]
  // HR-BENEFITS-04 — benefit enrollments for this employee.
  benefitEnrollments     EmployeeBenefit[]     @relation("EmployeeBenefits")
}

model EmployeeMedia {
  id             Int       @id @default(autoincrement())
  title          String?
  category       String?
  version        String?
  visibility     String    @default("all")
  effective_date String?
  expiry_date    String?
  notes          String?   @db.Text
  employee       Employee? @relation("employeeMedia", fields: [employee_id], references: [id])
  employee_id    Int?
  media_id       Int?
  file_name      String?
  mime_type      String?
  file_size      Int?
  download_url   String?
  uploaded_by_id Int?
  uploaded_at    DateTime  @default(now())
  status         String    @default("active")

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
}

model BusinessUnit {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  employees Employee[]

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
}

model GradeLevel {
  id          Int      @id @default(autoincrement())
  name        String // e.g., "G5", "Senior", "Associate"
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  employees Employee[]

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
}

model EmergencyContacts {
  id           Int       @id @default(autoincrement())
  Contact_name String?
  relationship String?
  phone        String?
  email        String?
  is_primary   Boolean   @default(false)
  employee_Id  Int?
  employee     Employee? @relation("RelationWithEmployee", fields: [employee_Id], references: [id])

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
}

model Log {
  id          Int       @id @default(autoincrement())
  employee    Employee? @relation(fields: [employeeId], references: [id])
  employeeId  Int?
  type        String
  action_type String
  module      String
  ip          String
  os          String
  result      String
  action_by   Employee? @relation("ActionBy", fields: [actionById], references: [id])
  actionById  Int?
  notes       String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  attendanceId Int?
  attendance   Attendance? @relation("AttendanceMark", fields: [attendanceId], references: [id])

  // Payroll relations
  payrollRun   PayrollRun?     @relation(fields: [payrollRunId], references: [id])
  payrollRunId Int?
  payslip      PayrollPayslip? @relation(fields: [payslipId], references: [id])
  payslipId    Int?

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
}

model Attendance {
  id          Int              @id @default(autoincrement())
  employeeId  Int
  date        DateTime         @default(now())
  check_in    DateTime?
  check_out   DateTime?
  total_hours Float?
  status      StatusAttendance @default(ABSENT)
  remarks     String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  logs     Log[]    @relation("AttendanceMark")

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
}

model Leave {
  id          Int         @id @default(autoincrement())
  employeeId  Int
  type        String
  start_date  DateTime
  end_date    DateTime
  total_days  Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  approved_by Int?
  approved_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
}

// ==================== LEAVE MANAGEMENT MODELS ====================

model LeavePolicy {
  id                  Int                @id @default(autoincrement())
  name                String
  description         String?
  leaveTypeCode       String?
  accrualRate         Float              @default(0.0)
  accrualPeriod       LeaveAccrualPeriod @default(NONE)
  carryForwardAllowed Boolean            @default(false)
  maxCarryForward     Float              @default(0.0)
  minServiceMonths    Int                @default(0)
  active              Boolean            @default(true)

  // Relations
  approvalWorkflow   ApprovalWorkflow? @relation(fields: [approvalWorkflowId], references: [id])
  approvalWorkflowId Int?
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]

  // Audit
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  createdBy   Employee  @relation("LeavePolicyCreatedBy", fields: [createdById], references: [id])
  createdById Int
  updatedBy   Employee? @relation("LeavePolicyUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@unique([name])
  @@index([tenantId])
  @@map("leave_policies")
}

model LeaveRequest {
  id            Int                @id @default(autoincrement())
  employeeId    Int
  leavePolicyId Int
  startDate     DateTime
  endDate       DateTime
  totalDays     Float
  reason        String?
  notes         String?
  status        LeaveRequestStatus @default(PENDING)

  // Relations
  employee    Employee               @relation(fields: [employeeId], references: [id])
  leavePolicy LeavePolicy            @relation(fields: [leavePolicyId], references: [id])
  approvals   LeaveRequestApproval[]

  // Audit
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  createdBy   Employee  @relation("LeaveRequestCreatedBy", fields: [createdById], references: [id])
  createdById Int
  updatedBy   Employee? @relation("LeaveRequestUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([tenantId])
  @@map("leave_requests")
}

model LeaveRequestApproval {
  id             Int              @id @default(autoincrement())
  leaveRequestId Int
  approverId     Int
  approverRole   String
  decision       ApprovalDecision
  comments       String?
  decision_date  DateTime         @default(now())

  // Relations
  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approver     Employee     @relation(fields: [approverId], references: [id])

  // Audit
  created_at  DateTime @default(now())
  createdBy   Employee @relation("LeaveRequestApprovalCreatedBy", fields: [createdById], references: [id])
  createdById Int

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([leaveRequestId])
  @@index([approverId])
  @@index([tenantId])
  @@map("leave_request_approvals")
}

model LeaveBalance {
  employeeId       Int
  leavePolicyId    Int
  balance          Float    @default(0.0)
  carryOverBalance Float    @default(0.0)
  lastUpdated      DateTime @default(now())

  // Relations
  employee    Employee    @relation(fields: [employeeId], references: [id])
  leavePolicy LeavePolicy @relation(fields: [leavePolicyId], references: [id])

  // Audit
  updatedBy   Employee? @relation("LeaveBalanceUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@id([employeeId, leavePolicyId])
  @@index([tenantId])
  @@map("leave_balances")
}

model ApprovalWorkflow {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  // Relations
  steps         ApprovalWorkflowStep[]
  leavePolicies LeavePolicy[]

  // Audit
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  createdBy   Employee  @relation("ApprovalWorkflowCreatedBy", fields: [createdById], references: [id])
  createdById Int
  updatedBy   Employee? @relation("ApprovalWorkflowUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@unique([name])
  @@index([tenantId])
  @@map("approval_workflows")
}

model ApprovalWorkflowStep {
  approvalWorkflowId Int
  stepOrder          Int
  approverRole       String

  // Relations
  approvalWorkflow ApprovalWorkflow @relation(fields: [approvalWorkflowId], references: [id], onDelete: Cascade)

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@id([approvalWorkflowId, stepOrder])
  @@index([tenantId])
  @@map("approval_workflow_steps")
}

model Region {
  id          Int     @id @default(autoincrement())
  name        String
  code        String?
  description String?

  // Relations
  holidayCalendars HolidayCalendar[]

  // Audit
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  createdBy   Employee   @relation("RegionCreatedBy", fields: [createdById], references: [id])
  createdById Int
  updatedBy   Employee?  @relation("RegionUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?
  Employee    Employee[]

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@unique([name])
  @@index([tenantId])
  @@map("regions")
}

model HolidayCalendar {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  year        Int?
  regionId    Int?

  // Relations
  region                   Region?                   @relation(fields: [regionId], references: [id])
  holidays                 Holiday[]
  employeeHolidayCalendars EmployeeHolidayCalendar[]

  // Audit
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  createdBy   Employee  @relation("HolidayCalendarCreatedBy", fields: [createdById], references: [id])
  createdById Int
  updatedBy   Employee? @relation("HolidayCalendarUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([tenantId])
  @@map("holiday_calendars")
}

model Holiday {
  id                Int      @id @default(autoincrement())
  holidayCalendarId Int
  date              DateTime
  name              String
  description       String?
  fullDay           Boolean  @default(true)

  // Relations
  holidayCalendar HolidayCalendar @relation(fields: [holidayCalendarId], references: [id], onDelete: Cascade)

  // Audit
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  createdBy   Employee  @relation("HolidayCreatedBy", fields: [createdById], references: [id])
  createdById Int
  updatedBy   Employee? @relation("HolidayUpdatedBy", fields: [updatedById], references: [id])
  updatedById Int?

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@unique([holidayCalendarId, date])
  @@index([tenantId])
  @@map("holidays")
}

model EmployeeHolidayCalendar {
  employeeId        Int
  holidayCalendarId Int
  effectiveFrom     DateTime  @default(now())
  effectiveTo       DateTime?

  // Relations
  employee        Employee        @relation(fields: [employeeId], references: [id])
  holidayCalendar HolidayCalendar @relation(fields: [holidayCalendarId], references: [id])

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@id([employeeId, holidayCalendarId, effectiveFrom])
  @@index([tenantId])
  @@map("employee_holiday_calendars")
}

// ==================== TIME ATTENDANCE MODELS ====================

model TimeEntry {
  id               Int           @id @default(autoincrement())
  employeeId       Int
  start_time       DateTime
  end_time         DateTime?
  work_date        DateTime
  duration_minutes Int?
  work_type        WorkType      @default(REGULAR)
  entry_type       TimeEntryType
  note             String?

  // Relations
  employee    Employee   @relation(fields: [employeeId], references: [id])
  source      Source?    @relation(fields: [sourceId], references: [id])
  sourceId    Int?
  timesheet   Timesheet? @relation(fields: [timesheetId], references: [id])
  timesheetId Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([employeeId, work_date])
  @@index([timesheetId])
  @@index([tenantId])
}

model Timesheet {
  id           Int             @id @default(autoincrement())
  employeeId   Int
  period_start DateTime
  period_end   DateTime
  total_hours  Float
  status       TimesheetStatus @default(DRAFT)
  submitted_at DateTime?
  approved_at  DateTime?

  // Relations
  employee    Employee       @relation(fields: [employeeId], references: [id])
  timeEntries TimeEntry[]
  approvals   TimeApproval[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@unique([employeeId, period_start, period_end])
  @@index([employeeId, status])
  @@index([tenantId])
}

model TimeApproval {
  id          Int              @id @default(autoincrement())
  timesheetId Int
  approverId  Int
  decision    ApprovalDecision
  comments    String?
  decided_at  DateTime         @default(now())

  // Relations
  timesheet Timesheet @relation(fields: [timesheetId], references: [id])
  approver  Employee  @relation(fields: [approverId], references: [id])

  created_at DateTime @default(now())

  tenantId String? @db.Uuid // C.2 / T-P2.2 / T-P2.6 — RBAC Company.uuid (verified service-JWT claim); nullable, fail-closed

  @@index([timesheetId])
  @@index([tenantId])
}

model OvertimeRule {
  id                     Int     @id @default(autoincrement())
  name                   String
  description            String?
  daily_hours_threshold  Float   @default(8.0)
  weekly_hours_threshold Float   @default(40.0)
